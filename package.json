{
  "name": "udla-qa",
  "version": "1.7.0",
  "description": "Agente CLI de QA y seguridad para web, basado en Claude Code (usa la suscripción del usuario)",
  "keywords": [
    "qa",
    "testing",
    "security",
    "pentesting",
    "playwright",
    "k6",
    "postman",
    "api-testing",
    "claude",
    "cli"
  ],
  "author": "Kevin Armas",
  "bin": {
    "udla-qa": "bin/udla-qa.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiwithecode/Cli-udla.git"
  },
  "homepage": "https://github.com/kiwithecode/Cli-udla#readme",
  "bugs": {
    "url": "https://github.com/kiwithecode/Cli-udla/issues"
  },
  "preferGlobal": true,
  "scripts": {
    "postinstall": "npx -y @playwright/mcp@latest install-browser chrome-for-testing",
